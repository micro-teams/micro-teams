{
  "name": "frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "codegen": "openapi-generator-cli generate -i ../MicroTeams-API.yml -g typescript-fetch -o src/api --additional-properties=supportsES6=true,withoutRuntimeChecks=true,prefixParameterInterfaces=true",
    "predev": "npm run codegen",
    "prebuild": "npm run codegen",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.ts\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xterm/addon-clipboard": "0.2.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "lucide-react": "^1.25.0",
    "marked": "^18.0.6",
    "radix-ui": "^1.6.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.15.3",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "~7.0.2",
    "vite": "^8.1.5"
  }
}
